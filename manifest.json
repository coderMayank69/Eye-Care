{
  "manifest_version": 3,
  "name": "Eye Care 20-20-20",
  "version": "1.0",
  "description": "Get reminders every 20 minutes to follow the 20-20-20 rule for eye health. Look at something 20 feet away for 20 seconds.",
  "permissions": [
    "notifications",
    "alarms",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Eye Care 20-20-20"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}